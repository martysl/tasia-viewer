<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<floater
	name="floater_tasiafeed"
	title="Upload to TasiaFeed"
	width="400"
	height="340"
	min_width="350"
	min_height="300">
	
	<text
		name="instructions_text"
		font="SansSerifSmall"
		length="1"
		follows="top|left"
		layout="topleft"
		left="10"
		top="10"
		width="380"
		height="20">
Upload your snapshot to TasiaFeed
	</text>
	
	<text
		name="title_label"
		font="SansSerifSmall"
		length="1"
		follows="top|left"
		layout="topleft"
		left="10"
		top="35"
		width="100"
		height="20">
Title:
	</text>
	<line_editor
		name="title_edit"
		follows="top|left|right"
		layout="topleft"
		left="120"
		top="35"
		width="260"
		height="20"
		max_length="255"
		length="1" />

	<text
		name="description_label"
		font="SansSerifSmall"
		length="1"
		follows="top|left"
		layout="topleft"
		left="10"
		top="60"
		width="100"
		height="20">
Description:
	</text>
	<line_editor
		name="description_edit"
		follows="top|left|right"
		layout="topleft"
		left="120"
		top="60"
		width="260"
		height="60"
		max_length="1000"
		length="1" />

	<text
		name="visibility_label"
		font="SansSerifSmall"
		length="1"
		follows="top|left"
		layout="topleft"
		left="10"
		top="130"
		width="100"
		height="20">
Visibility:
	</text>
	<combo_box
		name="visibility_combo"
		follows="top|left"
		layout="topleft"
		left="120"
		top="130"
		width="260"
		height="23">
		<combo_box.item
			label="Public"
			name="public"
			value="public" />
		<combo_box.item
			label="Unlisted"
			name="unlisted"
			value="unlisted" />
	</combo_box>

	<text
		name="maturity_label"
		font="SansSerifSmall"
		length="1"
		follows="top|left"
		layout="topleft"
		left="10"
		top="160"
		width="100"
		height="20">
Maturity:
	</text>
	<combo_box
		name="maturity_combo"
		follows="top|left"
		layout="topleft"
		left="120"
		top="160"
		width="260"
		height="23">
		<combo_box.item
			label="General"
			name="general"
			value="general" />
		<combo_box.item
			label="Moderate"
			name="moderate"
			value="moderate" />
		<combo_box.item
			label="Restricted"
			name="restricted"
			value="restricted" />
	</combo_box>

	<text
		name="result_text"
		font="SansSerifSmall"
		length="1"
		follows="top|left"
		layout="topleft"
		left="10"
		top="200"
		width="380"
		height="40"
		visible="false" />

	<button
		name="send_btn"
		label="Upload"
		font="SansSerif"
		follows="bottom|right"
		layout="topleft"
		left="200"
		top="300"
		width="90"
		height="25">
		<button.commit_callback
			function="TasiaFeed.Send" />
	</button>

	<button
		name="cancel_btn"
		label="Cancel"
		font="SansSerif"
		follows="bottom|right"
		layout="topleft"
		left="295"
		top="300"
		width="90"
		height="25">
		<button.commit_callback
			function="TasiaFeed.Cancel" />
	</button>
</floater>
